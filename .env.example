# ===== 飞书应用凭证 =====
# 飞书开放平台 -> 凭证与基础信息
APP_ID=cli_xxxxxxxxxxxx
APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书域：feishu（国内） 或 lark（国际）
LARK_DOMAIN=feishu

# ===== 鉴权白名单 =====
# 允许触发指令的群 chat_id（oc_ 开头），多个用逗号分隔
ALLOWED_CHAT_IDS=oc_xxxxxxxxxxxxxxxxxxxxxxxxxx
# 允许执行指令的管理员 open_id（ou_ 开头），多个用逗号分隔
ADMIN_USER_IDS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== MC / screen =====
# screen 会话名（只能 [A-Za-z0-9_-]）
SCREEN_SESSION=mc
# MC 启动脚本的绝对路径（支持 ~），机器人会在该脚本所在目录中执行
MC_START_SCRIPT=~/mc-server/start.sh
# stop 命令发送后等待 MC 退出的最长毫秒数
MC_GRACEFUL_TIMEOUT_MS=60000
# 启动后等待 screen 会话出现的最长毫秒数
MC_STARTUP_TIMEOUT_MS=15000

# ===== 日志 =====
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
